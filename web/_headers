# Cloudflare Pages headers. Keep the release manifest + its loader on a short TTL
# so a new release (or a fix to releases.js) propagates quickly instead of being
# pinned by a long edge cache. Other static assets keep their default caching.
/releases.json
  Cache-Control: public, max-age=60

/releases.js
  Cache-Control: public, max-age=60

# Images are content-stable (new art ships under new names), so cache them hard
# at the edge and in the browser for a year.
/img/*
  Cache-Control: public, max-age=31536000, immutable
